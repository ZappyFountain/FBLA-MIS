  \{t:"Project",d:"easy",q:"Which methodology follows a strict sequential phase order?",opts:["Scrum","Agile","Waterfall","Kanban"],a:2,exp:"Waterfall is linear and sequential \'97 each phase must be fully completed before the next begins."\},\
  \{t:"Project",d:"easy",q:"What does a Gantt chart primarily show?",opts:["Team member performance ratings","Project tasks and their timelines on a horizontal bar chart","Budget allocations","Risk assessment matrix"],a:1,exp:"A Gantt chart is a horizontal bar chart that shows project tasks, their durations, and timelines."\},\
  \{t:"Project",d:"easy",q:"In Agile, what is a user story?",opts:["A bug report","A short description of a feature from an end user's perspective","A project timeline document","A database schema diagram"],a:1,exp:"A user story captures a requirement in the format: 'As a [user], I want [feature] so that [benefit].'"\},\
  \{t:"Project",d:"medium",q:"Which Scrum ceremony focuses on improving the team's own process?",opts:["Sprint Review","Daily Standup","Sprint Retrospective","Backlog Refinement"],a:2,exp:"The Sprint Retrospective happens at end of each sprint and focuses on how the team worked, not what was built."\},\
  \{t:"Project",d:"medium",q:"A project is over budget and behind schedule but leadership keeps funding it. This is:",opts:["Scope Creep","Technical Debt","A Runaway Project","A Critical Path Failure"],a:2,exp:"A runaway project continues despite clear signs of failure, often due to the sunk cost fallacy."\},\
  \{t:"Project",d:"medium",q:"What does a burndown chart show?",opts:["Tasks completed by each member","Remaining work versus time in a sprint","Budget versus actual spend","Bugs found per day"],a:1,exp:"A burndown chart tracks how much work remains in a sprint over time, ideally trending to zero by sprint end."\},\
  \{t:"Project",d:"medium",q:"What is scope creep?",opts:["A runaway project that exceeds budget","Uncontrolled expansion of project requirements without adjusting time or budget","A type of security vulnerability","A Scrum ceremony for backlog review"],a:1,exp:"Scope creep is when project requirements grow beyond the original plan without corresponding adjustments to schedule or resources."\},\
  \{t:"Project",d:"medium",q:"Which methodology suits a government defense project with strict documentation requirements?",opts:["Scrum","Kanban","Agile","Waterfall"],a:3,exp:"Waterfall suits projects requiring extensive documentation, regulatory compliance, and fixed well-defined requirements \'97 common in government work."\},\
  \{t:"Project",d:"hard",q:"The Critical Path Method (CPM) identifies:",opts:["Team member workloads","The longest sequence of dependent tasks that determines project duration","Software testing coverage","Backlog priority order"],a:1,exp:"CPM identifies the critical path \'97 the longest chain of dependent tasks \'97 which determines the minimum project duration."\},\
  \{t:"Project",d:"hard",q:"Technical debt refers to:",opts:["Software license costs","Future rework cost from choosing quick solutions over better long-term approaches","Money owed to vendors","Hardware upgrade costs"],a:1,exp:"Technical debt is the implied future cost of reworking rushed or poorly written code."\},\
  \{t:"Project",d:"hard",q:"The 'Definition of Done' in Agile is:",opts:["A list of all backlog items","A shared agreement on criteria a story must meet to be complete","The project charter","The sprint goal statement"],a:1,exp:"The Definition of Done is a shared checklist (coded, tested, reviewed, documented) that a story must satisfy before being considered complete."\},\
  \{t:"Project",d:"hard",q:"Work Packages in a WBS are:",opts:["Milestones","Sprints","The lowest-level, assignable tasks with defined outputs","High-level project deliverables"],a:2,exp:"Work Packages are the lowest-level WBS components \'97 specific, assignable tasks with defined outputs that can be estimated and scheduled."\},\
  \{t:"Project",d:"hard",q:"The iron triangle of project management consists of:",opts:["Cost, Quality, Customer Satisfaction","Scope, Schedule, Cost","Agile, Scrum, Kanban","Planning, Execution, Closure"],a:1,exp:"The iron triangle shows the relationship between Scope, Schedule (time), and Cost \'97 changing one forces trade-offs in the others."\},\
  // Infrastructure\
  \{t:"Infra",d:"easy",q:"At which OSI layer do IP addresses operate?",opts:["Layer 2 \'97 Data Link","Layer 3 \'97 Network","Layer 4 \'97 Transport","Layer 7 \'97 Application"],a:1,exp:"Layer 3 (Network) handles logical addressing and routing. IP addresses operate at this layer, and routers work at Layer 3."\},\
  \{t:"Infra",d:"easy",q:"What does a firewall do?",opts:["Speeds up connections","Monitors and controls network traffic based on security rules","Stores backup data","Manages passwords"],a:1,exp:"A firewall monitors and filters network traffic according to predefined security rules to block unauthorized access."\},\
  \{t:"Infra",d:"easy",q:"What does LAN stand for?",opts:["Large Area Network","Local Area Network","Linked Application Network","Layered Access Network"],a:1,exp:"LAN (Local Area Network) connects devices within a limited geographic area like a building or campus."\},\
  \{t:"Infra",d:"easy",q:"What does WAN stand for?",opts:["Wide Area Network","Wireless Access Node","Web Application Network","Wired Area Network"],a:0,exp:"WAN (Wide Area Network) spans large geographic areas, connecting multiple LANs. The internet is the largest WAN."\},\
  \{t:"Infra",d:"easy",q:"Which OSI layer handles raw bit transmission over physical media?",opts:["Layer 1 \'97 Physical","Layer 2 \'97 Data Link","Layer 3 \'97 Network","Layer 4 \'97 Transport"],a:0,exp:"Layer 1 (Physical) handles the transmission of raw binary data (bits) over physical media like cables, fiber, or radio waves."\},\
  \{t:"Infra",d:"medium",q:"A network where every node connects to every other node is:",opts:["Star topology","Bus topology","Ring topology","Mesh topology"],a:3,exp:"Mesh topology provides full redundancy \'97 if one path fails, data can route through another path."\},\
  \{t:"Infra",d:"medium",q:"At which OSI layer do switches primarily operate?",opts:["Layer 1","Layer 2","Layer 3","Layer 4"],a:1,exp:"Switches operate at Layer 2 (Data Link) using MAC addresses to forward frames to the correct device on a local network."\},\
  \{t:"Infra",d:"medium",q:"Which cloud model provides virtualized servers and storage?",opts:["SaaS","PaaS","IaaS","DaaS"],a:2,exp:"IaaS (Infrastructure as a Service) provides virtualized hardware \'97 compute, storage, and networking. AWS EC2 is an example."\},\
  \{t:"Infra",d:"medium",q:"Which protocol automatically assigns IP addresses to network devices?",opts:["DNS","HTTP","DHCP","FTP"],a:2,exp:"DHCP (Dynamic Host Configuration Protocol) automatically assigns IP addresses and other network config to devices joining a network."\},\
  \{t:"Infra",d:"medium",q:"Which OSI layer handles data encryption and format translation?",opts:["Layer 4 \'97 Transport","Layer 5 \'97 Session","Layer 6 \'97 Presentation","Layer 7 \'97 Application"],a:2,exp:"Layer 6 (Presentation) handles data translation, encryption, and compression \'97 ensuring data is in a usable format for the application layer."\},\
  \{t:"Infra",d:"medium",q:"The main advantage of mesh over star topology is:",opts:["Lower cost","Central management","Redundant paths if one link fails","Simpler cabling"],a:2,exp:"Mesh topology provides multiple redundant paths between nodes, so if one link fails, traffic routes through another \'97 maximizing uptime."\},\
  \{t:"Infra",d:"hard",q:"Which security control ensures a user can only access resources their role permits?",opts:["Authentication","Encryption","Authorization","Intrusion Detection"],a:2,exp:"Authorization determines what an authenticated user is allowed to do \'97 it enforces access control policies based on roles or permissions."\},\
  \{t:"Infra",d:"hard",q:"Authentication vs. authorization \'97 which statement is correct?",opts:["Authentication checks permissions; authorization verifies identity","Authentication verifies identity; authorization determines what the user can access","They are the same concept","Authentication encrypts data; authorization stores it"],a:1,exp:"Authentication verifies who you are (login). Authorization determines what you're allowed to do after your identity is confirmed."\},\
  \{t:"Infra",d:"hard",q:"What is load balancing?",opts:["Measuring server CPU usage","Distributing network traffic across multiple servers to prevent overload","Compressing data before storage","Encrypting traffic between data centers"],a:1,exp:"Load balancing distributes incoming requests across multiple servers so no single server is overwhelmed, improving performance and availability."\},\
  \{t:"Infra",d:"hard",q:"What does SSL/TLS do in web communications?",opts:["Compresses web pages for faster loading","Encrypts data transmitted between a browser and server","Manages DNS lookups","Caches web content locally"],a:1,exp:"SSL/TLS encrypts the communication channel between a client and server, ensuring data like passwords cannot be intercepted."\},\
  \{t:"Infra",d:"hard",q:"A DDoS attack works by:",opts:["Injecting malicious SQL into a database","Flooding a server with traffic from multiple sources to make it unavailable","Stealing session cookies","Intercepting encrypted communications"],a:1,exp:"A DDoS (Distributed Denial of Service) attack uses many compromised systems to flood a target server, preventing legitimate access."\},\
  // Emerging Technologies\
  \{t:"Emerging",d:"easy",q:"What does IoT stand for?",opts:["Internet of Technology","Internet of Things","Integrated Open Technology","Interconnected Online Tools"],a:1,exp:"IoT (Internet of Things) refers to the network of physical devices embedded with sensors and connectivity to collect and exchange data."\},\
  \{t:"Emerging",d:"easy",q:"Which cloud service delivers software applications over the internet?",opts:["IaaS","PaaS","SaaS","DaaS"],a:2,exp:"SaaS (Software as a Service) delivers software over the internet. Examples include Gmail, Salesforce, and Canva."\},\
  \{t:"Emerging",d:"easy",q:"What is blockchain?",opts:["A type of relational database","A distributed, decentralized ledger that records transactions","A cloud storage service","A machine learning algorithm"],a:1,exp:"Blockchain is a distributed ledger where records are stored in linked blocks across a network, making tampering extremely difficult."\},\
  \{t:"Emerging",d:"easy",q:"Which is an example of IaaS?",opts:["Google Docs","Salesforce","Amazon EC2","Canva"],a:2,exp:"Amazon EC2 provides virtualized compute infrastructure on demand \'97 a classic IaaS offering. Google Docs and Salesforce are SaaS."\},\
  \{t:"Emerging",d:"easy",q:"What does AI stand for?",opts:["Automated Interface","Artificial Intelligence","Algorithmic Integration","Automated Indexing"],a:1,exp:"AI (Artificial Intelligence) refers to computer systems designed to perform tasks that typically require human intelligence."\},\
  \{t:"Emerging",d:"medium",q:"What makes blockchain data nearly impossible to alter retroactively?",opts:["Each block is stored on a single secure server","Each block contains a hash of the previous block, chaining them","Blockchain uses AES-256 on each entry","A central authority validates every change"],a:1,exp:"Each block stores a cryptographic hash of the previous block. Altering one block invalidates all subsequent hashes."\},\
  \{t:"Emerging",d:"medium",q:"A warehouse uses sensors to auto-adjust cooling systems. This is:",opts:["Blockchain","SaaS","Internet of Things","Robotic Process Automation"],a:2,exp:"IoT involves physical devices (sensors) connected to the internet that collect and act on data \'97 exactly what automated monitoring does."\},\
  \{t:"Emerging",d:"medium",q:"What is RPA?",opts:["Physical robots in a warehouse","Software bots that automate repetitive digital tasks","A machine learning algorithm","An IoT sensor network"],a:1,exp:"RPA (Robotic Process Automation) uses software robots to automate repetitive, structured digital tasks like data entry and form filling."\},\
  \{t:"Emerging",d:"medium",q:"Which AI application analyzes customer sentiment from product reviews?",opts:["Computer Vision","Natural Language Processing","Robotic Process Automation","Blockchain"],a:1,exp:"NLP (Natural Language Processing) enables computers to understand and analyze human language \'97 sentiment analysis is a core NLP application."\},\
  \{t:"Emerging",d:"medium",q:"What is edge computing?",opts:["Computing in large centralized data centers","Processing data near the source rather than in a central cloud","A type of blockchain network","A SaaS delivery model"],a:1,exp:"Edge computing processes data at or near the source (e.g., IoT devices) rather than sending it to a central cloud, reducing latency."\},\
  \{t:"Emerging",d:"hard",q:"Supervised vs. unsupervised machine learning \'97 the key difference is:",opts:["Supervised uses more data","Supervised uses labeled data; unsupervised finds patterns in unlabeled data","Unsupervised is always more accurate","Supervised cannot be used in business"],a:1,exp:"Supervised learning trains on labeled data (known inputs/outputs). Unsupervised finds hidden patterns in data without predefined labels."\},\
  \{t:"Emerging",d:"hard",q:"ETL in a data warehouse stands for:",opts:["Encrypt, Transfer, Load","Extract, Transform, Load","Export, Test, Launch","Evaluate, Track, Log"],a:1,exp:"ETL (Extract, Transform, Load) pulls data from source systems, cleans and transforms it, then loads it into a data warehouse for analysis."\},\
  \{t:"Emerging",d:"hard",q:"Proof of Work in blockchain requires:",opts:["Staking cryptocurrency as collateral","Solving complex mathematical puzzles to validate transactions","A central authority's approval","Digital signatures from all members"],a:1,exp:"Proof of Work requires miners to expend computational effort (solving puzzles) to validate transactions \'97 this is what Bitcoin uses."\},\
  \{t:"Emerging",d:"hard",q:"What distinguishes deep learning from traditional machine learning?",opts:["Deep learning requires less data","Deep learning uses multi-layered neural networks to automatically learn feature representations","Deep learning cannot handle image recognition","Deep learning only works on structured data"],a:1,exp:"Deep learning uses deep neural networks with many layers to automatically learn hierarchical features from raw data, unlike traditional ML requiring manual feature engineering."\},\
  \{t:"Emerging",d:"hard",q:"Which cloud characteristic means resources can scale up or down rapidly to meet demand?",opts:["Broad network access","On-demand self-service","Rapid elasticity","Resource pooling"],a:2,exp:"Rapid elasticity is an NIST cloud characteristic meaning resources can be scaled out or in quickly \'97 sometimes automatically \'97 to match demand."\},\
];\
\
function shuffle(arr)\{const a=[...arr];for(let i=a.length-1;i>0;i--)\{const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];\}return a;\}\
\
let filtered=shuffle([...Q]);\
let idx=0,answered=false,correct=0,wrong=0,wrongSet=[],topicStats=\{\};\
let mode='standard',selOpt=null;\
let currentTab='practice';\
\
function applyFilters()\{\
  const t=document.getElementById('topic-filter').value;\
  const d=document.getElementById('diff-filter').value;\
  filtered=shuffle(Q.filter(q=>(t==='all'||q.t.includes(t))&&(d==='all'||q.d===d)));\
  idx=0;correct=0;wrong=0;answered=false;selOpt=null;\
  renderQ();updateStats();\
\}\
\
function shuffleReset()\{filtered=shuffle([...filtered]);idx=0;correct=0;wrong=0;answered=false;selOpt=null;renderQ();updateStats();\}\
\
function setMode(m)\{\
  mode=m;\
  document.getElementById('mode-std').classList.toggle('active',m==='standard');\
  document.getElementById('mode-ai').classList.toggle('active',m==='ai');\
  idx=0;correct=0;wrong=0;answered=false;selOpt=null;renderQ();updateStats();\
\}\
\
function renderQ()\{\
  const area=document.getElementById('q-area');\
  if(idx>=filtered.length)\{\
    area.innerHTML=`<div class="q-card complete-card">\
      <h2>Session complete! \uc0\u55356 \u57225 </h2>\
      <p>You answered all $\{filtered.length\} questions.<br>Accuracy: $\{correct+wrong>0?Math.round(correct/(correct+wrong)*100):0\}%</p>\
      <button class="nav-btn primary" style="max-width:200px;margin:0 auto;" onclick="shuffleReset()">Start over</button>\
    </div>`;\
    return;\
  \}\
  const q=filtered[idx];\
  answered=false;selOpt=null;\
  document.getElementById('prog').style.width=Math.round(idx/filtered.length*100)+'%';\
  document.getElementById('q-counter').textContent=`Question $\{idx+1\} of $\{filtered.length\}`;\
\
  const metaHtml=`<div class="q-meta">\
    <span class="badge badge-topic">$\{q.t\}</span>\
    <span class="badge badge-$\{q.d\}">$\{q.d.charAt(0).toUpperCase()+q.d.slice(1)\}</span>\
    $\{mode==='ai'?'<span class="badge badge-ai">AI Grader</span>':''\}\
  </div>`;\
  const optsHtml=q.opts.map((o,i)=>`<button class="opt" id="opt-$\{i\}" onclick="$\{mode==='standard'?'selStd':'selAI'\}($\{i\})">\
    <span class="opt-letter">$\{String.fromCharCode(65+i)\}</span>$\{o\}</button>`).join('');\
\
  if(mode==='standard')\{\
    area.innerHTML=`<div class="q-card">$\{metaHtml\}<div class="q-text">$\{q.q\}</div>\
      <div class="options">$\{optsHtml\}</div>\
      <div id="fb" style="display:none;" class="feedback-box"></div>\
      <div class="nav-btns" style="margin-top:1rem;">\
        <button class="nav-btn" onclick="prevQ()" $\{idx===0?'disabled':''\}>\uc0\u8592  Prev</button>\
        <button class="nav-btn primary" onclick="nextQ()">Next \uc0\u8594 </button>\
      </div></div>`;\
  \} else \{\
    area.innerHTML=`<div class="q-card">$\{metaHtml\}<div class="q-text">$\{q.q\}</div>\
      <div class="options">$\{optsHtml\}</div>\
      <div id="rationale-box" style="display:none;" class="rationale-box">\
        <div class="rationale-label">\
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>\
          Why did you choose that answer? Explain your reasoning:\
        </div>\
        <textarea id="rationale-input" placeholder="Type your reasoning here..."></textarea>\
        <button class="submit-btn" id="submit-btn" onclick="submitRationale()">\
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>\
          Submit for AI grading\
        </button>\
      </div>\
      <div id="ai-result" style="display:none;" class="feedback-box"></div>\
      <div id="nav-after" style="display:none;" class="nav-btns">\
        <button class="nav-btn" onclick="prevQ()" $\{idx===0?'disabled':''\}>\uc0\u8592  Prev</button>\
        <button class="nav-btn primary" onclick="nextQ()">Next \uc0\u8594 </button>\
      </div></div>`;\
  \}\
\}\
\
function selStd(i)\{\
  if(answered)return;answered=true;\
  const q=filtered[idx];\
  document.querySelectorAll('.opt').forEach((o,j)=>\{\
    o.disabled=true;\
    if(j===q.a)o.classList.add('correct');\
    else if(j===i&&i!==q.a)o.classList.add('wrong');\
  \});\
  const fb=document.getElementById('fb');\
  fb.style.display='block';\
  if(i===q.a)\{correct++;fb.className='feedback-box good';fb.innerHTML='<div class="feedback-label">\uc0\u10003  Correct</div>'+q.exp;track(q,true);\}\
  else\{wrong++;fb.className='feedback-box bad';fb.innerHTML='<div class="feedback-label">\uc0\u10007  Incorrect</div>'+q.exp;track(q,false);\}\
  updateStats();\
\}\
\
function selAI(i)\{\
  if(answered)return;selOpt=i;\
  document.querySelectorAll('.opt').forEach((o,j)=>o.classList.toggle('selected',j===i));\
  document.getElementById('rationale-box').style.display='block';\
  setTimeout(()=>document.getElementById('rationale-input').focus(),50);\
\}\
\
async function submitRationale()\{\
  if(selOpt===null)return;\
  const r=document.getElementById('rationale-input').value.trim();\
  if(!r)\{document.getElementById('rationale-input').style.borderColor='var(--red)';return;\}\
  const q=filtered[idx];\
  const isC=selOpt===q.a;\
  const btn=document.getElementById('submit-btn');\
  btn.disabled=true;btn.textContent='Grading...';\
  document.querySelectorAll('.opt').forEach((o,j)=>\{\
    o.disabled=true;\
    if(j===q.a)o.classList.add('correct');\
    else if(j===selOpt&&!isC)o.classList.add('wrong');\
    o.classList.remove('selected');\
  \});\
  const result=document.getElementById('ai-result');\
  result.style.display='block';result.className='feedback-box loading';result.textContent='Claude is reviewing your reasoning...';\
\
  const prompt=`You are grading an FBLA MIS student's answer. Be concise \'97 3-4 sentences max total.\
\
Question: "$\{q.q\}"\
Correct answer: $\{String.fromCharCode(65+q.a)\}. $\{q.opts[q.a]\}\
Student chose: $\{String.fromCharCode(65+selOpt)\}. $\{q.opts[selOpt]\}\
Student's reasoning: "$\{r\}"\
Answer was: $\{isC?'CORRECT':'INCORRECT'\}\
\
Assess the quality of their reasoning (was it sound, even if they got lucky?), then give a brief explanation of the core concept. Format exactly: "Reasoning: [Strong/Partial/Weak] \'97 [1-2 sentences]. Key concept: [1-2 sentences]."`;\
\
  try\{\
    const resp=await fetch('https://api.anthropic.com/v1/messages',\{method:'POST',headers:\{'Content-Type':'application/json'\},body:JSON.stringify(\{model:'claude-sonnet-4-6',max_tokens:1000,messages:[\{role:'user',content:prompt\}]\})\});\
    const data=await resp.json();\
    const text=data.content.map(c=>c.text||'').join('');\
    result.className='feedback-box '+(isC?'good':'bad');\
    result.innerHTML=`<div class="feedback-label">$\{isC?'\uc0\u10003  Correct':'\u10007  Incorrect'\}</div>$\{text\}`;\
    answered=true;\
    if(isC)\{correct++;track(q,true);\}else\{wrong++;track(q,false);\}\
    document.getElementById('nav-after').style.display='flex';\
    updateStats();\
  \}catch(e)\{\
    result.className='feedback-box '+(isC?'good':'bad');\
    result.innerHTML=`<div class="feedback-label">$\{isC?'\uc0\u10003  Correct':'\u10007  Incorrect'\}</div>$\{q.exp\}`;\
    answered=true;\
    if(isC)\{correct++;track(q,true);\}else\{wrong++;track(q,false);\}\
    document.getElementById('nav-after').style.display='flex';\
    updateStats();\
  \}\
\}\
\
function track(q,isC)\{\
  topicStats[q.t]=topicStats[q.t]||\{c:0,w:0\};\
  if(isC)topicStats[q.t].c++;\
  else\{topicStats[q.t].w++;if(!wrongSet.find(x=>x.q===q.q))wrongSet.push(q);updateBadge();\}\
\}\
\
function updateBadge()\{\
  const b=document.getElementById('learn-badge');\
  b.textContent=wrongSet.length;b.classList.toggle('show',wrongSet.length>0);\
\}\
\
function nextQ()\{if(idx<filtered.length-1)\{idx++;renderQ();\}\}\
function prevQ()\{if(idx>0)\{idx--;renderQ();\}\}\
\
function updateStats()\{\
  const total=correct+wrong;\
  document.getElementById('s-total').textContent=filtered.length;\
  document.getElementById('s-correct').textContent=correct;\
  document.getElementById('s-wrong').textContent=wrong;\
  document.getElementById('s-acc').textContent=total>0?Math.round(correct/total*100)+'%':'\'97';\
  document.getElementById('ss-acc').textContent=total>0?Math.round(correct/total*100)+'%':'\'97';\
  document.getElementById('ss-learn').textContent=wrongSet.length;\
\}\
\
function renderLearnTab()\{\
  const el=document.getElementById('learn-list');\
  if(!wrongSet.length)\{el.innerHTML='<div class="learn-empty"><div class="icon">\uc0\u9989 </div>No questions to review yet.<br>Wrong answers from your practice session will appear here.</div>';return;\}\
  el.innerHTML=wrongSet.map((q,qi)=>`<div class="q-card" style="margin-bottom:1rem;">\
    <div class="q-meta"><span class="badge badge-topic">$\{q.t\}</span><span class="badge badge-$\{q.d\}">$\{q.d.charAt(0).toUpperCase()+q.d.slice(1)\}</span></div>\
    <div class="q-text">$\{q.q\}</div>\
    <div class="options" id="lopts-$\{qi\}">$\{q.opts.map((o,i)=>`<button class="opt" onclick="selLearn($\{qi\},$\{i\})"><span class="opt-letter">$\{String.fromCharCode(65+i)\}</span>$\{o\}</button>`).join('')\}</div>\
    <div id="lfb-$\{qi\}" style="display:none;" class="feedback-box"></div>\
    <button onclick="rmLearn($\{qi\})" style="margin-top:10px;background:transparent;border:1px solid var(--border2);border-radius:var(--radius-sm);color:var(--muted);font-size:12px;padding:6px 12px;cursor:pointer;">\uc0\u10003  Mark as learned</button>\
  </div>`).join('');\
\}\
\
function selLearn(qi,i)\{\
  const q=wrongSet[qi];\
  document.querySelectorAll(`#lopts-$\{qi\} .opt`).forEach((o,j)=>\{o.disabled=true;if(j===q.a)o.classList.add('correct');else if(j===i&&i!==q.a)o.classList.add('wrong');\});\
  const fb=document.getElementById(`lfb-$\{qi\}`);\
  fb.style.display='block';fb.className='feedback-box '+(i===q.a?'good':'bad');\
  fb.innerHTML=`<div class="feedback-label">$\{i===q.a?'\uc0\u10003  Correct':'\u10007  Incorrect'\}</div>$\{q.exp\}`;\
\}\
\
function rmLearn(qi)\{wrongSet.splice(qi,1);updateBadge();document.getElementById('ss-learn').textContent=wrongSet.length;renderLearnTab();\}\
\
function renderTopicBreakdown()\{\
  const topics=['Systems Design','OOP','Data','Project','Infra','Emerging'];\
  const labels=\{'Systems Design':'Systems Design & Analysis','OOP':'OOP Concepts','Data':'Data & Information Mgmt','Project':'IT Project Management','Infra':'IT Infrastructure','Emerging':'Emerging Technologies'\};\
  document.getElementById('topic-breakdown').innerHTML=topics.map(t=>\{\
    const s=topicStats[t]||\{c:0,w:0\};const total=s.c+s.w;const pct=total?Math.round(s.c/total*100):0;\
    return `<div class="topic-row">\
      <div class="topic-row-header"><span class="topic-name">$\{labels[t]\}</span><span class="topic-score">$\{s.c\}/$\{total\} correct$\{total?` ($\{pct\}%)`:''\}` +'</span></div>'+\
      `<div class="topic-bar"><div class="topic-bar-fill" style="width:$\{pct\}%"></div></div></div>`;\
  \}).join('');\
\}\
\
function showTab(name)\{\
  currentTab=name;\
  ['practice','learn','stats'].forEach(n=>document.getElementById('tab-'+n).style.display=n===name?'':'none');\
  document.querySelectorAll('.nav-tab').forEach((b,i)=>b.classList.toggle('active',['practice','learn','stats'][i]===name));\
  document.querySelectorAll('.mobile-tab').forEach((b,i)=>b.classList.toggle('active',['practice','learn','stats'][i]===name));\
  if(name==='learn')renderLearnTab();\
  if(name==='stats')renderTopicBreakdown();\
\}\
\
renderQ();updateStats();\
</script>\
</body>\
</html>}
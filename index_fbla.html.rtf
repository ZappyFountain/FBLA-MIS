      <div class="stat-card"><div class="stat-label">Incorrect</div><div class="stat-val red" id="s-wrong">0</div></div>\
      <div class="stat-card"><div class="stat-label">Accuracy</div><div class="stat-val accent" id="s-acc">\'97</div></div>\

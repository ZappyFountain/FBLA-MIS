\f0\fs24 \cf0 <!DOCTYPE html>\
<html lang="en">\
<head>\
<meta charset="UTF-8">\
<meta name="viewport" content="width=device-width, initial-scale=1.0">\
<title>FBLA MIS Study Tool</title>\
<style>\
  :root \{\
    --bg: #0f1117;\
    --surface: #1a1d27;\
    --surface2: #22263a;\
    --border: rgba(255,255,255,0.08);\
    --border2: rgba(255,255,255,0.14);\
    --text: #f0f0f5;\
    --muted: #8b8fa8;\
    --accent: #6c6ef7;\
    --accent-dim: rgba(108,110,247,0.15);\
    --accent-border: rgba(108,110,247,0.4);\
    --green: #34d399;\
    --green-dim: rgba(52,211,153,0.12);\
    --green-border: rgba(52,211,153,0.3);\
    --red: #f87171;\
    --red-dim: rgba(248,113,113,0.12);\
    --red-border: rgba(248,113,113,0.3);\
    --yellow: #fbbf24;\
    --yellow-dim: rgba(251,191,36,0.12);\
    --yellow-border: rgba(251,191,36,0.3);\
    --radius: 10px;\
    --radius-sm: 6px;\
  \}\
  * \{ box-sizing: border-box; margin: 0; padding: 0; \}\
  body \{ background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; min-height: 100vh; \}\
\
  .header \{ border-bottom: 1px solid var(--border); padding: 0 1.5rem; display: flex; align-items: center; gap: 1rem; height: 56px; \}\
  .logo \{ font-size: 15px; font-weight: 600; letter-spacing: -0.02em; display: flex; align-items: center; gap: 8px; \}\
  .logo-badge \{ background: var(--accent); color: white; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 4px; letter-spacing: 0.05em; \}\
  .nav-tabs \{ display: flex; gap: 2px; margin-left: auto; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 3px; \}\
  .nav-tab \{ padding: 5px 14px; font-size: 13px; border: none; background: transparent; color: var(--muted); cursor: pointer; border-radius: 4px; transition: all 0.15s; \}\
  .nav-tab.active \{ background: var(--surface2); color: var(--text); \}\
  .nav-tab .badge \{ background: var(--red-dim); color: var(--red); border: 1px solid var(--red-border); border-radius: 99px; padding: 1px 6px; font-size: 10px; margin-left: 4px; display: none; \}\
  .nav-tab .badge.show \{ display: inline; \}\
\
  .main \{ max-width: 780px; margin: 0 auto; padding: 1.5rem; \}\
\
  .controls \{ display: flex; gap: 8px; margin-bottom: 1.25rem; flex-wrap: wrap; align-items: center; \}\
  .mode-toggle \{ display: flex; gap: 0; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; \}\
  .mode-btn \{ padding: 7px 14px; font-size: 13px; border: none; background: transparent; color: var(--muted); cursor: pointer; transition: all 0.15s; display: flex; align-items: center; gap: 6px; \}\
  .mode-btn.active \{ background: var(--surface2); color: var(--text); \}\
  .mode-btn svg \{ width: 14px; height: 14px; \}\
\
  select \{ background: var(--surface); border: 1px solid var(--border2); border-radius: var(--radius-sm); color: var(--text); font-size: 13px; padding: 7px 10px; cursor: pointer; outline: none; \}\
  select:focus \{ border-color: var(--accent); \}\
\
  .shuffle-btn \{ margin-left: auto; background: var(--surface); border: 1px solid var(--border2); border-radius: var(--radius-sm); color: var(--muted); font-size: 13px; padding: 7px 12px; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: all 0.15s; \}\
  .shuffle-btn:hover \{ color: var(--text); border-color: var(--accent-border); \}\
\
  .stats-row \{ display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 1.25rem; \}\
  .stat-card \{ background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 12px 14px; \}\
  .stat-label \{ font-size: 11px; color: var(--muted); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.06em; \}\
  .stat-val \{ font-size: 22px; font-weight: 600; letter-spacing: -0.02em; \}\
  .stat-val.green \{ color: var(--green); \}\
  .stat-val.red \{ color: var(--red); \}\
  .stat-val.accent \{ color: var(--accent); \}\
\
  .progress-track \{ height: 3px; background: var(--surface2); border-radius: 99px; margin-bottom: 6px; overflow: hidden; \}\
  .progress-fill \{ height: 100%; background: var(--accent); border-radius: 99px; transition: width 0.4s ease; \}\
  .q-counter \{ font-size: 12px; color: var(--muted); margin-bottom: 1rem; \}\
\
  .q-card \{ background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; \}\
  .q-meta \{ display: flex; gap: 6px; margin-bottom: 14px; flex-wrap: wrap; \}\
  .badge \{ font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 99px; \}\
  .badge-topic \{ background: var(--accent-dim); color: var(--accent); border: 1px solid var(--accent-border); \}\
  .badge-easy \{ background: var(--green-dim); color: var(--green); border: 1px solid var(--green-border); \}\
  .badge-medium \{ background: var(--yellow-dim); color: var(--yellow); border: 1px solid var(--yellow-border); \}\
  .badge-hard \{ background: var(--red-dim); color: var(--red); border: 1px solid var(--red-border); \}\
  .badge-ai \{ background: rgba(168,85,247,0.12); color: #c084fc; border: 1px solid rgba(168,85,247,0.3); \}\
\
  .q-text \{ font-size: 16px; line-height: 1.6; font-weight: 500; margin-bottom: 1.25rem; letter-spacing: -0.01em; \}\
\
  .options \{ display: flex; flex-direction: column; gap: 8px; \}\
  .opt \{ background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 11px 14px; font-size: 14px; cursor: pointer; text-align: left; color: var(--text); transition: all 0.12s; display: flex; align-items: flex-start; gap: 10px; \}\
  .opt-letter \{ font-size: 11px; font-weight: 700; color: var(--muted); background: var(--border); border-radius: 4px; padding: 2px 6px; flex-shrink: 0; margin-top: 1px; \}\
  .opt:hover:not(:disabled) \{ border-color: var(--accent-border); background: var(--accent-dim); \}\
  .opt.selected \{ border-color: var(--accent-border); background: var(--accent-dim); \}\
  .opt.selected .opt-letter \{ color: var(--accent); \}\
  .opt.correct \{ border-color: var(--green-border); background: var(--green-dim); \}\
  .opt.correct .opt-letter \{ color: var(--green); \}\
  .opt.wrong \{ border-color: var(--red-border); background: var(--red-dim); \}\
  .opt.wrong .opt-letter \{ color: var(--red); \}\
  .opt:disabled \{ cursor: default; \}\
\
  .rationale-box \{ margin-top: 16px; background: var(--bg); border: 1px solid var(--border2); border-radius: var(--radius); padding: 14px; \}\
  .rationale-label \{ font-size: 13px; color: var(--muted); margin-bottom: 10px; display: flex; align-items: center; gap: 6px; \}\
  .rationale-label svg \{ width: 14px; height: 14px; color: var(--accent); \}\
  textarea \{ width: 100%; background: var(--surface); border: 1px solid var(--border2); border-radius: var(--radius-sm); color: var(--text); font-size: 14px; font-family: inherit; padding: 10px 12px; resize: vertical; min-height: 80px; outline: none; line-height: 1.5; \}\
  textarea:focus \{ border-color: var(--accent); \}\
  textarea::placeholder \{ color: var(--muted); \}\
  .submit-btn \{ margin-top: 10px; width: 100%; padding: 10px; background: var(--accent); border: none; border-radius: var(--radius-sm); color: white; font-size: 14px; font-weight: 600; cursor: pointer; transition: opacity 0.15s; display: flex; align-items: center; justify-content: center; gap: 6px; \}\
  .submit-btn:hover \{ opacity: 0.9; \}\
  .submit-btn:disabled \{ opacity: 0.4; cursor: default; \}\
  .submit-btn svg \{ width: 14px; height: 14px; \}\
\
  .feedback-box \{ margin-top: 14px; padding: 14px; border-radius: var(--radius-sm); font-size: 14px; line-height: 1.65; \}\
  .feedback-box.loading \{ color: var(--muted); font-style: italic; border: 1px solid var(--border); background: var(--surface2); \}\
  .feedback-box.good \{ background: var(--green-dim); border: 1px solid var(--green-border); color: #a7f3d0; \}\
  .feedback-box.bad \{ background: var(--red-dim); border: 1px solid var(--red-border); color: #fca5a5; \}\
  .feedback-box.partial \{ background: var(--yellow-dim); border: 1px solid var(--yellow-border); color: #fde68a; \}\
  .feedback-label \{ font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; opacity: 0.7; margin-bottom: 6px; \}\
\
  .nav-btns \{ display: flex; gap: 8px; margin-top: 1rem; \}\
  .nav-btn \{ flex: 1; padding: 10px; background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text); font-size: 14px; cursor: pointer; transition: all 0.12s; \}\
  .nav-btn:hover:not(:disabled) \{ border-color: var(--accent-border); \}\
  .nav-btn:disabled \{ opacity: 0.3; cursor: default; \}\
  .nav-btn.primary \{ background: var(--accent-dim); border-color: var(--accent-border); color: var(--accent); font-weight: 600; \}\
\
  .complete-card \{ text-align: center; padding: 3rem 1.5rem; \}\
  .complete-card h2 \{ font-size: 22px; font-weight: 600; margin-bottom: 8px; \}\
  .complete-card p \{ color: var(--muted); font-size: 14px; margin-bottom: 1.5rem; \}\
\
  .learn-empty \{ text-align: center; padding: 3rem; color: var(--muted); background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); font-size: 14px; \}\
  .learn-empty .icon \{ font-size: 2rem; margin-bottom: 8px; \}\
\
  .topic-row \{ background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 12px 14px; margin-bottom: 8px; \}\
  .topic-row-header \{ display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; \}\
  .topic-name \{ font-size: 13px; font-weight: 500; \}\
  .topic-score \{ font-size: 13px; color: var(--muted); \}\
  .topic-bar \{ height: 4px; background: var(--surface2); border-radius: 99px; overflow: hidden; \}\
  .topic-bar-fill \{ height: 100%; background: var(--green); border-radius: 99px; transition: width 0.4s; \}\
\
  .section-title \{ font-size: 13px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 12px; \}\
\
  .code \{ font-family: 'SF Mono', 'Fira Code', monospace; font-size: 13px; background: var(--bg); padding: 1px 5px; border-radius: 3px; border: 1px solid var(--border2); \}\
\
  @media (max-width: 600px) \{\
    .stats-row \{ grid-template-columns: repeat(2, 1fr); \}\
    .header \{ padding: 0 1rem; \}\
    .main \{ padding: 1rem; \}\
    .nav-tabs \{ display: none; \}\
    .mobile-tabs \{ display: flex; \}\
  \}\
  .mobile-tabs \{ display: none; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 3px; margin-bottom: 1rem; \}\
  .mobile-tab \{ flex: 1; padding: 7px; font-size: 13px; border: none; background: transparent; color: var(--muted); cursor: pointer; border-radius: 4px; transition: all 0.15s; \}\
  .mobile-tab.active \{ background: var(--surface2); color: var(--text); \}\
</style>\
</head>\
<body>\
\
